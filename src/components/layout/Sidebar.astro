---
import { siteConfig } from '../../siteConfig';
import Icon from '../ui/Icon.astro';
import ThemeToggle from '../ui/ThemeToggle.astro';

interface Props {
  page: 'home' | 'about' | 'notes' | 'projects' | 'lab' | 'cv';
  lang: 'ko' | 'en';
  alternatePath?: string;
}

const { page, lang, alternatePath } = Astro.props;

const prefix = lang === 'en' ? '/en' : '';
const profile = siteConfig.profile[lang];
const labels = {
  home: lang === 'ko' ? '홈' : 'Home',
  about: lang === 'ko' ? '소개' : 'About',
  notes: lang === 'ko' ? '노트' : 'Notes',
  projects: lang === 'ko' ? '프로젝트' : 'Projects',
  lab: lang === 'ko' ? '실험실' : 'Lab',
  cv: 'CV',
};

const navItems = [
  { id: 'home', href: `${prefix}/`, icon: 'terminal' },
  { id: 'about', href: `${prefix}/about/`, icon: 'map' },
  { id: 'notes', href: `${prefix}/notes/`, icon: 'book' },
  { id: 'projects', href: `${prefix}/projects/`, icon: 'layers' },
  { id: 'lab', href: `${prefix}/lab/`, icon: 'flask' },
  { id: 'cv', href: `${prefix}/cv/`, icon: 'file' },
] as const;

const koPath = lang === 'ko' ? Astro.url.pathname : (alternatePath ?? '/');
const enPath = lang === 'en' ? Astro.url.pathname : (alternatePath ?? '/en/');
---

<aside class="sidebar">
  <div class="brand-row">
    <a class="brand" href={prefix || '/'} aria-label="Bit City Lab">
      <img class="brand-logo" src="/images/blog-logo.png" alt="" width="32" height="32" aria-hidden="true" />
      <span class="brand-text">Bit City Lab</span>
    </a>
    <button
      class="icon-button sidebar-toggle"
      type="button"
      data-sidebar-toggle
      data-collapse-label={lang === 'ko' ? '사이드바 접기' : 'Collapse sidebar'}
      data-expand-label={lang === 'ko' ? '사이드바 펼치기' : 'Expand sidebar'}
      aria-label={lang === 'ko' ? '사이드바 접기' : 'Collapse sidebar'}
      aria-expanded="true"
    >
      <span class="sidebar-toggle-icon sidebar-toggle-collapse"><Icon name="panel-close" /></span>
      <span class="sidebar-toggle-icon sidebar-toggle-expand"><Icon name="panel-open" /></span>
    </button>
  </div>

  <section class="sidebar-profile" aria-label={lang === 'ko' ? '프로필 요약' : 'Profile summary'}>
    <img class="sidebar-profile-image" src={siteConfig.profileImage} alt={profile.name} width="80" height="80" />
    <div class="sidebar-profile-copy">
      <p class="sidebar-profile-role">{profile.role}</p>
      <h2>{profile.name}</h2>
      <p>{profile.bio}</p>
    </div>
  </section>

  <nav aria-label={lang === 'ko' ? '주요 탐색' : 'Primary navigation'}>
    <ul class="nav-list">
      {navItems.map((item) => (
        <li>
          <a class="nav-item" href={item.href} aria-label={labels[item.id]} aria-current={page === item.id ? 'page' : undefined}>
            <Icon name={item.icon} />
            <span>{labels[item.id]}</span>
          </a>
        </li>
      ))}
    </ul>
  </nav>

  <div class="sidebar-footer">
    <div class="language-links" aria-label={lang === 'ko' ? '언어 선택' : 'Language selection'}>
      <a href={koPath} aria-current={lang === 'ko' ? 'true' : undefined}>KO</a>
      <a href={enPath} aria-current={lang === 'en' ? 'true' : undefined}>EN</a>
    </div>
    <div class="utility-row">
      <a class="icon-button" href={siteConfig.githubUrl} aria-label="GitHub"><Icon name="github" /></a>
      <a class="icon-button" href={`mailto:${siteConfig.email}`} aria-label="Email"><Icon name="mail" /></a>
      <ThemeToggle lang={lang} />
    </div>
  </div>
</aside>

<script>
  (() => {
    const root = document.documentElement;
    const button = document.querySelector('[data-sidebar-toggle]');

    if (!(button instanceof HTMLButtonElement)) return;

    const setSidebarState = (collapsed) => {
      root.dataset.sidebar = collapsed ? 'collapsed' : 'expanded';
      button.setAttribute('aria-expanded', String(!collapsed));
      button.setAttribute(
        'aria-label',
        collapsed ? button.dataset.expandLabel || 'Expand sidebar' : button.dataset.collapseLabel || 'Collapse sidebar',
      );

      try {
        localStorage.setItem('portfolio-sidebar', collapsed ? 'collapsed' : 'expanded');
      } catch {
        // Persisting the sidebar state is optional.
      }
    };

    setSidebarState(root.dataset.sidebar === 'collapsed');

    button.addEventListener('click', () => {
      setSidebarState(root.dataset.sidebar !== 'collapsed');
    });
  })();
</script>
