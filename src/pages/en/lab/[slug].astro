---
import { getCollection } from 'astro:content';
import Base from '../../../layouts/Base.astro';
import BadgeList from '../../../components/ui/BadgeList.astro';
import { getLocalizedStaticPaths, getSlugWithoutLangPrefix } from '../../../lib/content/collections';
import BilevelToyDemo from '../../../components/lab/BilevelToyDemo.astro';
import { getStatusLabel, getStatusTone } from '../../../lib/content/status';

export async function getStaticPaths() {
  return getLocalizedStaticPaths(await getCollection('lab'), 'en', 'entry');
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const slug = getSlugWithoutLangPrefix(entry.slug);
---

<Base title={entry.data.title} page="lab" lang="en" alternatePath={`/lab/${slug}/`}>
  <article class="page-stack lab-detail-stack">
    <header class="page-header">
      <div class="metadata">
        <span>{entry.data.tier}</span>
        <span data-tone={getStatusTone(entry.data.status)}>{getStatusLabel(entry.data.status, entry.data.lang)}</span>
        <span>{entry.data.runtime}</span>
      </div>
      <h1 class="page-title">{entry.data.title}</h1>
      <p class="lede">{entry.data.question}</p>
      <BadgeList items={entry.data.tags} />
    </header>

    <BilevelToyDemo lang="en" />

    <div class="prose">
      <Content />
    </div>
  </article>
</Base>
