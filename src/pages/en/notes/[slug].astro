---
import { getCollection } from 'astro:content';
import Base from '../../../layouts/Base.astro';
import BadgeList from '../../../components/ui/BadgeList.astro';
import { getLocalizedStaticPaths, getSlugWithoutLangPrefix } from '../../../lib/content/collections';
import { getNoteFieldLabel } from '../../../lib/content/fields';
import { getStatusLabel, getStatusTone } from '../../../lib/content/status';

export async function getStaticPaths() {
  return getLocalizedStaticPaths(await getCollection('notes'), 'en', 'note');
}

const { note } = Astro.props;
const { Content } = await note.render();
const slug = getSlugWithoutLangPrefix(note.slug);
---

<Base title={note.data.title} page="notes" lang="en" alternatePath={`/notes/${slug}/`}>
  <article class="page-stack">
    <header class="page-header">
      <div class="metadata">
        <span>{note.data.date.toISOString().slice(0, 10)}</span>
        <span>{getNoteFieldLabel(note.data.field, note.data.lang)}</span>
        {note.data.series && <span>{note.data.series}</span>}
        <span>{note.data.category}</span>
        <span data-tone={getStatusTone(note.data.status)}>{getStatusLabel(note.data.status, note.data.lang)}</span>
      </div>
      <h1 class="page-title">{note.data.title}</h1>
      <p class="lede">{note.data.summary}</p>
      <BadgeList items={note.data.tags} />
    </header>
    <div class="prose">
      <Content />
    </div>
  </article>
</Base>
